# -------------------------------------------------------------------
# TidePool -- Environment Configuration
# Copy to .env and update values for your deployment.
# -------------------------------------------------------------------

# -- Database --
DB_PASSWORD=tidepool_dev
DATABASE_URL=postgresql+asyncpg://tidepool:${DB_PASSWORD}@postgres:5432/tidepool

# -- Redis --
REDIS_URL=redis://redis:6379/0

# -- Celery --
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -- Application --
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=false
LOG_LEVEL=info
CORS_ORIGINS=["http://localhost:3000"]

# -- SMTP --
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_ADDRESS=noreply@tidepool.local

# Campaign header signing (mail gateway allowlisting)
TIDEPOOL_HEADER_ENABLED=true
TIDEPOOL_HEADER_SECRET=
